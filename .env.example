# Copy to .env.local and fill in real values.
# Never commit .env.local.

# Node
NODE_ENV=development

# Database (Supabase)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres"

# Auth
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI
OPENAI_API_KEY=""

# Cache / rate limit
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# WhatsApp (Twilio Sandbox in dev)
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# Email (Resend)
RESEND_API_KEY=""

# Observability
SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# Public
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=""
NEXT_PUBLIC_SENTRY_DSN=""
