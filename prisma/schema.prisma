// Prisma schema for Gita-Verse
// See: https://www.prisma.io/docs

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────
// Core content (public-read)
// ─────────────────────────────────────────────────────────

model Chapter {
  id         Int     @id
  number     Int     @unique
  titleSa    String
  titleEn    String
  titleHi    String
  summary    String  @db.Text
  verseCount Int
  verses     Verse[]

  @@map("chapters")
}

model Verse {
  id              Int      @id @default(autoincrement())
  chapterId       Int
  number          Int
  sanskrit        String   @db.Text
  transliteration String   @db.Text
  hindi           String   @db.Text
  english         String   @db.Text
  wordMeanings    Json?
  themes          String[]
  moods           String[]
  embedding       Unsupported("vector(1536)")?

  chapter        Chapter        @relation(fields: [chapterId], references: [id])
  bookmarks      Bookmark[]
  journalEntries JournalEntry[]
  commentaries   Commentary[]
  moodLogs       MoodLog[]

  @@unique([chapterId, number])
  @@index([themes], type: Gin)
  @@map("verses")
}

model Commentary {
  id       Int    @id @default(autoincrement())
  verseId  Int
  author   String
  language String
  text     String @db.Text
  source   String

  verse Verse @relation(fields: [verseId], references: [id])

  @@map("commentaries")
}

// ─────────────────────────────────────────────────────────
// Users & personalization (RLS enforced in Supabase)
// ─────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  preferredLanguage String    @default("en")
  whatsappOptIn     Boolean   @default(false)
  whatsappNumber    String?
  streakDays        Int       @default(0)
  lastReadAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bookmarks      Bookmark[]
  journalEntries JournalEntry[]
  moodLogs       MoodLog[]
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    String
  verseId   Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse @relation(fields: [verseId], references: [id])

  @@unique([userId, verseId])
  @@index([userId, createdAt])
  @@map("bookmarks")
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  verseId   Int
  content   String   @db.Text
  mood      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse @relation(fields: [verseId], references: [id])

  @@index([userId, createdAt])
  @@map("journal_entries")
}

model MoodLog {
  id        Int      @id @default(autoincrement())
  userId    String
  mood      String
  verseId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse @relation(fields: [verseId], references: [id])

  @@index([userId, createdAt])
  @@map("mood_logs")
}

// ─────────────────────────────────────────────────────────
// AI cache (cross-user)
// ─────────────────────────────────────────────────────────

model AiQueryCache {
  id           String   @id @default(cuid())
  questionHash String   @unique
  question     String   @db.Text
  verseIds     Int[]
  explanation  String   @db.Text
  language     String
  createdAt    DateTime @default(now())
  hitCount     Int      @default(1)

  @@map("ai_query_cache")
}
