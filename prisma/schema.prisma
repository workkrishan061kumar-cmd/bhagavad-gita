// Prisma schema for Gita-Verse
// See: https://www.prisma.io/docs

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────
// Metadata: Languages
// ─────────────────────────────────────────────────────────
// Seeded with 22 Indian official languages + 10 major world languages.
// `enabled` controls UI visibility — toggle on once translations land.

model Language {
  id           Int      @id @default(autoincrement())
  code         String   @unique // 'en', 'hi', 'ta', 'sa' (ISO 639-1 or 3)
  name         String // English name: 'English', 'Hindi', 'Tamil'
  nativeName   String // Native script: 'English', 'हिन्दी', 'தமிழ்'
  direction    String   @default("ltr") // 'ltr' or 'rtl'
  enabled      Boolean  @default(false) // shown in UI selector
  isIndian     Boolean  @default(false) // Indian Constitution 8th Schedule
  sortOrder    Int      @default(100)

  translations VerseTranslation[]
  recitations  VerseRecitation[]
  commentaries Commentary[]

  @@map("languages")
}

// ─────────────────────────────────────────────────────────
// Metadata: Authors (translators, commentators, reciters)
// ─────────────────────────────────────────────────────────

model Author {
  id         Int     @id @default(autoincrement())
  externalId Int?    @unique // matches gita repo's author.id
  name       String
  slug       String  @unique
  bio        String? @db.Text
  era        String? // '16th century', 'Modern', etc.
  tradition  String? // 'Advaita', 'Vaishnava', etc.

  translations VerseTranslation[]
  commentaries Commentary[]
  recitations  VerseRecitation[] @relation("AuthorRecitations")

  @@map("authors")
}

// ─────────────────────────────────────────────────────────
// Core content
// ─────────────────────────────────────────────────────────

model Chapter {
  id         Int     @id
  number     Int     @unique
  titleSa    String
  titleEn    String
  titleHi    String
  summary    String  @db.Text // English summary
  summaryHi  String? @db.Text // Hindi summary (from chapters.json)
  verseCount Int
  verses     Verse[]

  @@map("chapters")
}

model Verse {
  id              Int     @id @default(autoincrement())
  externalId      Int?    @unique // matches gita repo's verse.id (global 1-701)
  chapterId       Int
  number          Int // verse number within chapter
  sanskrit        String  @db.Text // Devanagari (invariant)
  transliteration String  @db.Text // IAST (invariant)
  wordMeanings    String? @db.Text // word-by-word breakdown
  themes          String[]
  moods           String[]
  embedding       Unsupported("vector(1536)")?

  chapter        Chapter            @relation(fields: [chapterId], references: [id])
  translations   VerseTranslation[]
  commentaries   Commentary[]
  recitations    VerseRecitation[]
  bookmarks      Bookmark[]
  journalEntries JournalEntry[]
  moodLogs       MoodLog[]

  @@unique([chapterId, number])
  @@index([themes], type: Gin)
  @@map("verses")
}

// ─────────────────────────────────────────────────────────
// VerseTranslation — many-to-many: verse × language × author
// ─────────────────────────────────────────────────────────

model VerseTranslation {
  id         Int      @id @default(autoincrement())
  verseId    Int
  authorId   Int
  languageId Int
  text       String   @db.Text
  isFeatured Boolean  @default(false) // default pick for this language
  source     String? // attribution / publisher
  createdAt  DateTime @default(now())

  verse    Verse    @relation(fields: [verseId], references: [id])
  author   Author   @relation(fields: [authorId], references: [id])
  language Language @relation(fields: [languageId], references: [id])

  @@unique([verseId, authorId, languageId])
  @@index([languageId, isFeatured])
  @@map("verse_translations")
}

// ─────────────────────────────────────────────────────────
// VerseRecitation — many-to-many: verse × language × reciter
// ─────────────────────────────────────────────────────────

model VerseRecitation {
  id              Int      @id @default(autoincrement())
  verseId         Int
  reciterId       Int // points to Author (used as reciter)
  languageId      Int // typically Sanskrit
  audioUrl        String // Supabase Storage public URL
  durationSeconds Int?
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())

  verse    Verse    @relation(fields: [verseId], references: [id])
  reciter  Author   @relation("AuthorRecitations", fields: [reciterId], references: [id])
  language Language @relation(fields: [languageId], references: [id])

  @@unique([verseId, reciterId, languageId])
  @@map("verse_recitations")
}

// ─────────────────────────────────────────────────────────
// Commentary — separate from translation, longer-form analysis
// ─────────────────────────────────────────────────────────

model Commentary {
  id         Int    @id @default(autoincrement())
  verseId    Int
  authorId   Int
  languageId Int
  text       String @db.Text
  source     String

  verse    Verse    @relation(fields: [verseId], references: [id])
  author   Author   @relation(fields: [authorId], references: [id])
  language Language @relation(fields: [languageId], references: [id])

  @@index([verseId])
  @@map("commentaries")
}

// ─────────────────────────────────────────────────────────
// Users & personalization (RLS enforced in Supabase)
// ─────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  name              String?
  image             String?
  preferredLanguage String    @default("en")
  preferredAuthorId Int? // user's chosen translator
  whatsappOptIn     Boolean   @default(false)
  whatsappNumber    String?
  streakDays        Int       @default(0)
  lastReadAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bookmarks      Bookmark[]
  journalEntries JournalEntry[]
  moodLogs       MoodLog[]
  accounts       Account[]
  sessions       Session[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    String
  verseId   Int
  note      String?  @db.Text
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse @relation(fields: [verseId], references: [id])

  @@unique([userId, verseId])
  @@index([userId, createdAt])
  @@map("bookmarks")
}

model JournalEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  verseId   Int
  content   String   @db.Text
  mood      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse @relation(fields: [verseId], references: [id])

  @@index([userId, createdAt])
  @@map("journal_entries")
}

model MoodLog {
  id        Int      @id @default(autoincrement())
  userId    String
  mood      String
  verseId   Int
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  verse Verse @relation(fields: [verseId], references: [id])

  @@index([userId, createdAt])
  @@map("mood_logs")
}

// ─────────────────────────────────────────────────────────
// AI cache (cross-user)
// ─────────────────────────────────────────────────────────

model AiQueryCache {
  id           String   @id @default(cuid())
  questionHash String   @unique
  question     String   @db.Text
  verseIds     Int[]
  explanation  String   @db.Text
  language     String
  createdAt    DateTime @default(now())
  hitCount     Int      @default(1)

  @@map("ai_query_cache")
}
